modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "cloudrun"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
JWT_SECRET = "06c92cfc22a02b6d23671273d4a91f22dc9779a45da0d041fa66ebb660222886ff1ec2a7ec51e4f65f38174cfba466fb"
API_PORT = "8080"
ALLOWED_ORIGINS = "*"
